@startuml PowerPlant Platform - System Architecture
!define RECTANGLE class

title PowerPlant Platform - System Architecture Overview

!define AWSPUML https://raw.githubusercontent.com/awslabs/aws-icons-for-plantuml/v18.0/dist
!include AWSPUML/AWSCommon.puml
!include AWSPUML/ApplicationIntegration/APIGateway.puml
!include AWSPUML/Compute/ECS.puml
!include AWSPUML/Database/RDS.puml
!include AWSPUML/Database/ElastiCache.puml
!include AWSPUML/Storage/S3.puml

' External Systems
actor "Data Administrator" as admin
actor "Business Analyst" as analyst
actor "API Consumer" as api_user

' Frontend Layer
package "Frontend Layer" {
  [React Web Application] as web_app
  [Mobile App (Future)] as mobile_app
}

' API Layer
package "API Gateway Layer" {
  APIGateway(api_gateway, "API Gateway", "NestJS")
}

' Microservices Layer
package "Microservices Layer" {
  ECS(auth_service, "Auth Service", "NestJS + JWT")
  ECS(query_service, "Query Service", "NestJS + Cache")
  ECS(ingestion_service, "Data Ingestion", "NestJS + Queue")
  ECS(notification_service, "Notification Service", "NestJS")
}

' Message Layer
package "Message Bus" {
  [RabbitMQ] as message_bus
}

' Data Layer
package "Data Layer" {
  RDS(primary_db, "PostgreSQL", "Primary Database")
  ElastiCache(cache, "Redis", "Cache Layer")
  S3(object_store, "MinIO/S3", "Object Storage")
}

' Monitoring Layer
package "Observability" {
  [Prometheus] as metrics
  [Grafana] as dashboards
  [Jaeger] as tracing
  [ELK Stack] as logs
}

' External Data Sources
cloud "External Data" {
  [EPA eGRID Data] as epa_data
  [Energy APIs] as energy_apis
}

' User Interactions
admin --> web_app : Upload CSV Files
analyst --> web_app : View Analytics
api_user --> api_gateway : API Requests

' Frontend to API Gateway
web_app --> api_gateway : HTTPS/REST
mobile_app --> api_gateway : HTTPS/REST

' API Gateway to Services
api_gateway --> auth_service : Authentication
api_gateway --> query_service : Data Queries
api_gateway --> ingestion_service : File Processing
api_gateway --> notification_service : Notifications

' Service to Service Communication
auth_service --> message_bus : Auth Events
query_service --> message_bus : Query Events
ingestion_service --> message_bus : Processing Events
notification_service --> message_bus : Notification Events

' Services to Data Layer
auth_service --> primary_db : User Data
query_service --> primary_db : Read Operations
query_service --> cache : Cache Access
ingestion_service --> primary_db : Write Operations
ingestion_service --> object_store : File Storage

' External Data Integration
ingestion_service --> epa_data : Data Import
ingestion_service --> energy_apis : API Integration

' Monitoring Integration
auth_service --> metrics : Metrics
query_service --> metrics : Metrics
ingestion_service --> metrics : Metrics
api_gateway --> metrics : Metrics

metrics --> dashboards : Visualization
auth_service --> tracing : Traces
query_service --> tracing : Traces
ingestion_service --> tracing : Traces

auth_service --> logs : Logs
query_service --> logs : Logs
ingestion_service --> logs : Logs
api_gateway --> logs : Logs

note right of api_gateway
  • JWT Authentication
  • Rate Limiting
  • Request Routing
  • API Documentation
end note

note right of query_service
  • Redis Caching
  • Pagination
  • Advanced Filtering
  • Analytics Aggregation
end note

note right of ingestion_service
  • CSV File Processing
  • Data Validation
  • ETL Pipeline
  • Progress Tracking
end note

note bottom of primary_db
  • ACID Compliance
  • Connection Pooling
  • Read Replicas
  • Backup & Recovery
end note

@enduml 