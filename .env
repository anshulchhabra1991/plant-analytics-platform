# Database Configuration
POSTGRES_USER=plantuser
POSTGRES_PASSWORD=plantpassword123
POSTGRES_DB=plant_analytics

# Airflow Database Configuration (separate database for Airflow)
AIRFLOW_FERNET_KEY=YlCImzjge_TeZc6jGlfZ8xu5Avn5r1MjEYxEhRjyJ-Y=
AIRFLOW_SECRET_KEY=your-secret-key-here

# Redis Configuration
REDIS_PASSWORD=redispass123

# RabbitMQ Configuration
RABBITMQ_USER=egriduser
RABBITMQ_PASSWORD=egridpass123
RABBITMQ_VHOST=/

# MinIO Configuration
MINIO_ROOT_USER=egriduser
MINIO_ROOT_PASSWORD=egridpass123
MINIO_BUCKET=egrid-data


# Application Ports
BACKEND_PORT=3000
GATEWAY_PORT=8000
POSTGRES_EXTERNAL_PORT=5432
REDIS_EXTERNAL_PORT=6379
AIRFLOW_WEBSERVER_PORT=8081
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
RABBITMQ_PORT=5672

# Application Environment
NODE_ENV=development
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Airflow Configuration
AIRFLOW_EXECUTOR=LocalExecutor
AIRFLOW_LOAD_EXAMPLES=False
AIRFLOW_EXPOSE_CONFIG=True

# Database Versions
POSTGRES_VERSION=15
REDIS_VERSION=7
RABBITMQ_VERSION=3
MINIO_VERSION=latest
